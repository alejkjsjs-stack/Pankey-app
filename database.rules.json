{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && (!data.exists() ? newData.child('uid').val() === auth.uid : data.child('uid').val() === auth.uid)",
        "uid": {
          ".validate": "newData.val() === auth.uid"
        },
        "appState": {
          "energy":  { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 5)" },
          "isPro":   { ".validate": "!newData.exists() || newData.isBoolean()" },
          "ryo":     { ".validate": "!newData.exists() || newData.isNumber()" },
          "xp":      { ".validate": "!newData.exists() || newData.isNumber()" }
        }
      }
    },

    "uids": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "sessions": {
      "$sid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "partnerRequests": {
      "$toCode": {
        ".read": "auth != null",
        "$fromCode": {
          ".write": "auth != null && ( root.child('users').child($toCode).child('uid').val() === auth.uid || ( newData.exists() && $fromCode === root.child('uids').child(auth.uid).val() ) )"
        }
      }
    },

    "friendRequests": {
      "$toCode": {
        ".read": "auth != null",
        "$fromCode": {
          ".write": "auth != null && ( root.child('users').child($toCode).child('uid').val() === auth.uid || ( newData.exists() && $fromCode === root.child('uids').child(auth.uid).val() ) )"
        }
      }
    },

    "friendships": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "presence": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "duels": {
      ".read": "auth != null",
      "$code": { ".write": "auth != null" }
    },

    "flashQueue": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "flashMatch": {
      ".read": "auth != null",
      "$code": { ".write": "auth != null" }
    },
    "flashRooms": {
      ".read": "auth != null",
      "$roomId": { ".write": "auth != null" }
    }
  }
}
